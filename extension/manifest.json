{
  "manifest_version": 3,
  "name": "Verity",
  "description": "Fact-check the social post currently visible in the active tab.",
  "version": "0.1.0",
  "action": {
    "default_title": "Fact-check visible post",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16-black.png",
      "32": "icons/icon32-black.png",
      "48": "icons/icon48-black.png",
      "128": "icons/icon128-black.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["theme-detector.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["activeTab", "contextMenus", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://*/*",
    "https://*/*"
  ]
}
